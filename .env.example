APP_NAME="ChurnStream"
APP_ENV=local
DEBUG=true
LOG_LEVEL=INFO

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-address>/?retryWrites=true&w=majority
MONGODB_DATABASE=churnstream
MONGODB_COLLECTION=customers

MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=10000
MONGODB_MAX_POOL_SIZE=20

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=churnstream-training

MLFLOW_REGISTERED_MODEL_NAME=churnstream-classifier
MLFLOW_MODEL_ALIAS=champion

MODEL_PATH=artifacts/model.pkl
MODEL_METADATA_PATH=artifacts/model_metadata.json